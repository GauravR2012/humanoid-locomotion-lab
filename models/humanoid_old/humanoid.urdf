<robot name="research_humanoid">

<link name="torso">
  <inertial>
    <mass value="10"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
  </inertial>
</link>

<link name="left_thigh">
  <inertial>
    <mass value="2"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
  </inertial>
</link>

<link name="left_shin">
  <inertial>
    <mass value="2"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.1" iyy="0.1" izz="0.1"/>
  </inertial>
</link>

<link name="left_foot">
  <inertial>
    <mass value="1"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.05" iyy="0.05" izz="0.05"/>
  </inertial>
</link>

<link name="right_thigh">
  <inertial>
    <mass value="2"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.1" iyy="0.1" izz="0.1"/>
  </inertial>
</link>

<link name="right_shin">
  <inertial>
    <mass value="2"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.1" iyy="0.1" izz="0.1"/>
  </inertial>
</link>

<link name="right_foot">
  <inertial>
    <mass value="1"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.05" iyy="0.05" izz="0.05"/>
  </inertial>
</link>

<joint name="left_hip" type="revolute">
  <parent link="torso"/>
  <child link="left_thigh"/>
  <origin xyz="0 0.1 -0.2"/>
  <axis xyz="1 0 0"/>
  <limit lower="-1.5" upper="1.5" effort="10" velocity="2"/>
</joint>

<joint name="left_knee" type="revolute">
  <parent link="left_thigh"/>
  <child link="left_shin"/>
  <origin xyz="0 0 -0.4"/>
  <axis xyz="1 0 0"/>
  <limit lower="-1.5" upper="0" effort="10" velocity="2"/>
</joint>

<joint name="left_ankle" type="revolute">
  <parent link="left_shin"/>
  <child link="left_foot"/>
  <origin xyz="0 0 -0.4"/>
  <axis xyz="1 0 0"/>
  <limit lower="-0.5" upper="0.5" effort="10" velocity="2"/>
</joint>

<joint name="right_hip" type="revolute">
  <parent link="torso"/>
  <child link="right_thigh"/>
  <origin xyz="0 -0.1 -0.2"/>
  <axis xyz="1 0 0"/>
  <limit lower="-1.5" upper="1.5" effort="10" velocity="2"/>
</joint>

<joint name="right_knee" type="revolute">
  <parent link="right_thigh"/>
  <child link="right_shin"/>
  <origin xyz="0 0 -0.4"/>
  <axis xyz="1 0 0"/>
  <limit lower="-1.5" upper="0" effort="10" velocity="2"/>
</joint>

<joint name="right_ankle" type="revolute">
  <parent link="right_shin"/>
  <child link="right_foot"/>
  <origin xyz="0 0 -0.4"/>
  <axis xyz="1 0 0"/>
  <limit lower="-0.5" upper="0.5" effort="10" velocity="2"/>
</joint>

</robot>